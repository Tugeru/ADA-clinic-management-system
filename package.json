{
  "name": "ada-monorepo",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev:web": " pnpm --filter @ada/web dev",
    "dev:api": "pnpm --filter @ada/api dev",
    "dev": "concurrently -k -n API,WEB -c cyan,teal \"pnpm run dev:api\" \"pnpm run dev:web\"",
    "build": "pnpm --filter @ada/web build",
    "build:all": "pnpm -r build",
    "prod:api": "pnpm --filter @ada/api start",
    "prod:web": "pnpm --filter @ada/web preview -- --port 5173",
    "prod:both": "concurrently -k -n API,WEB -c cyan,teal \"pnpm run prod:api\" \"pnpm run prod:web\"",
    "prod:all": "pnpm build:all && pnpm run prod:both"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@tailwindcss/oxide",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}