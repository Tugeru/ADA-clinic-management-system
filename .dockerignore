# ─── Version control ─────────────────────────────────────────────────────────
.git
.gitignore

# ─── Dependencies (reinstalled inside the image) ─────────────────────────────
node_modules
apps/*/node_modules
packages/*/node_modules

# ─── Build artifacts (rebuilt inside the image) ──────────────────────────────
apps/*/dist
packages/*/dist

# ─── Frontend app (not needed for API container) ─────────────────────────────
apps/web

# ─── Environment files (secrets must not be baked into the image) ────────────
.env
.env.*
*.env

# ─── Infrastructure config (used outside the container) ─────────────────────
infra/

# ─── Documentation ───────────────────────────────────────────────────────────
docs/
*.md
!apps/api/README.md

# ─── Cursor / IDE ────────────────────────────────────────────────────────────
.cursor/
.vscode/

# ─── OS artefacts ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Test directories ────────────────────────────────────────────────────────
tests/
apps/api/tests/
