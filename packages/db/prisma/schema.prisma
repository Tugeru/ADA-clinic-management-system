generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model ReferenceData {
  id          String   @id @default(uuid()) @db.Uuid
  category    String
  value       String
  label       String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  parentValue String?  @map("parent_value")

  @@unique([category, value])
  @@map("reference_data")
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique
  passwordHash   String     @map("password_hash")
  fullName       String     @map("full_name")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  canManageUsers Boolean    @default(false) @map("can_manage_users")
  auditLogs      AuditLog[]
  visits         Visit[]

  @@map("users")
}

model Student {
  id                     String    @id @default(uuid()) @db.Uuid
  fullName               String    @map("full_name")
  gradeLevel             String?   @map("grade_level")
  section                String?
  dateOfBirth            DateTime? @map("date_of_birth") @db.Date
  gender                 String?
  knownMedicalConditions String?   @map("known_medical_conditions")
  isArchived             Boolean   @default(false) @map("is_archived")
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  contactName            String?   @map("contact_name")
  contactNumber          String?   @map("contact_number")
  contactRelationship    String?   @map("contact_relationship")
  department             String?
  patientType            String    @default("Student") @map("patient_type")
  position               String?
  strand                 String?
  schoolYear             String?   @map("school_year")
  firstName              String?   @map("first_name")
  middleName             String?   @map("middle_name")
  lastName               String?   @map("last_name")
  visits                 Visit[]

  @@map("students")
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Medicine {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @unique
  description      String?
  purpose          String?
  reorderThreshold Int              @default(0) @map("reorder_threshold")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  batches          InventoryBatch[]
  visitMedicines   VisitMedicine[]

  @@map("medicines")
}

model InventoryBatch {
  id                String             @id @default(uuid()) @db.Uuid
  medicineId        String             @map("medicine_id") @db.Uuid
  batchNumber       String?            @map("batch_number")
  expirationDate    DateTime?          @map("expiration_date") @db.Date
  quantityOnHand    Int                @default(0) @map("quantity_on_hand")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  isHidden          Boolean            @default(false) @map("is_hidden")
  hiddenAt          DateTime?          @map("hidden_at") @db.Timestamptz(6)
  hiddenReason      String?            @map("hidden_reason")
  medicine          Medicine           @relation(fields: [medicineId], references: [id])
  stockTransactions StockTransaction[]
  visitMedicines    VisitMedicine[]

  @@unique([medicineId, batchNumber, expirationDate], name: "uq_batch")
  @@index([medicineId, isHidden])
  @@map("inventory_batches")
}

model StockTransaction {
  id               String          @id @default(uuid()) @db.Uuid
  batchId          String          @map("batch_id") @db.Uuid
  txnType          TransactionType @map("txn_type")
  quantity         Int
  referenceVisitId String?         @map("reference_visit_id") @db.Uuid
  notes            String?
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  batch            InventoryBatch  @relation(fields: [batchId], references: [id])
  referenceVisit   Visit?          @relation(fields: [referenceVisitId], references: [id])

  @@map("stock_transactions")
}

model Visit {
  id                     String             @id @default(uuid()) @db.Uuid
  studentId              String             @map("student_id") @db.Uuid
  loggedByUserId         String             @map("logged_by_user_id") @db.Uuid
  visitDate              DateTime           @default(now()) @map("visit_date") @db.Date
  timeIn                 DateTime           @map("time_in") @db.Timestamptz(6)
  timeOut                DateTime?          @map("time_out") @db.Timestamptz(6)
  complaint              String
  actionTaken            String             @map("action_taken")
  remarks                String?
  releasedToName         String?            @map("released_to_name")
  releasedToRelationship String?            @map("released_to_relationship")
  releaseTime            DateTime?          @map("release_time") @db.Timestamptz(6)
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  bloodPressure          String?            @map("blood_pressure")
  heartRate              String?            @map("heart_rate")
  respiratoryRate        String?            @map("respiratory_rate")
  temperature            String?
  disposition            Disposition        @default(RETURNED_TO_CLASS)
  isArchived             Boolean            @default(false) @map("is_archived")
  stockTransactions      StockTransaction[]
  visitMedicines         VisitMedicine[]
  loggedByUser           User               @relation(fields: [loggedByUserId], references: [id])
  student                Student            @relation(fields: [studentId], references: [id])

  @@map("visits")
}

model VisitMedicine {
  id                String          @id @default(uuid()) @db.Uuid
  visitId           String          @map("visit_id") @db.Uuid
  medicineId        String          @map("medicine_id") @db.Uuid
  batchId           String?         @map("batch_id") @db.Uuid
  quantityDispensed Int             @map("quantity_dispensed")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  batch             InventoryBatch? @relation(fields: [batchId], references: [id])
  medicine          Medicine        @relation(fields: [medicineId], references: [id])
  visit             Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@map("visit_medicines")
}

model AuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  userId           String   @map("user_id") @db.Uuid
  action           String
  entity           String
  entityId         String?  @map("entity_id") @db.Uuid
  recordIdentifier String?  @map("record_identifier")
  metadata         Json?
  user             User     @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entity, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// Types of stock transactions for the inventory audit trail.
enum TransactionType {
  IN
  OUT
  ADJUST
}

/// Outcome/disposition of a clinic visit.
enum Disposition {
  RETURNED_TO_CLASS
  RETURNED_TO_WORK
  SENT_HOME
  SENT_TO_HOSPITAL
}
