# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://username:password@host:port/database?schema=public
# Validation: Must be a valid URL format
DATABASE_URL="postgresql://postgres:password@localhost:5432/ada_dev?schema=public"

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Backend API base URL (REQUIRED for frontend)
# Validation: Must be a valid URL (no /v1 suffix - routes are at /api)
VITE_API_BASE_URL=http://localhost:3000/api

# ─── Auth / JWT ──────────────────────────────────────────────────────────────
# JWT signing secret (REQUIRED)
# Validation: Minimum 8 characters (recommend 32+ for production)
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Allowed CORS origin (defaults to http://localhost:5173)
# Validation: Must be a valid URL
CORS_ORIGIN=http://localhost:5173

# ─── Render keep-alive (optional) ─────────────────────────────────────────────
# Prevent free Render web service from sleeping by self-pinging /api/health.
# Keep disabled for local development and tests.
SELF_PING_ENABLED=false

# Optional explicit API base URL to ping (e.g. https://your-api.onrender.com)
# If omitted, API falls back to RENDER_EXTERNAL_URL when available.
# SELF_PING_BASE_URL=

# Recommended interval for free Render: 10 minutes
SELF_PING_INTERVAL_MS=600000

# Timeout for each keep-alive request
SELF_PING_TIMEOUT_MS=10000
